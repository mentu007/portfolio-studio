---
import DynamicSidebar from '../components/DynamicSidebar';
import GalleryFilter from '../components/GalleryFilter';
import HeroBanner from '../components/HeroBanner.astro';
import CompactTimeline from '../components/CompactTimeline';
import SectionHeading from '../components/SectionHeading.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { siteProfile } from '../data/site';
import { formatProjectDate, getProjects, getTagIndex } from '../utils/projects';

const projects = await getProjects();
const tags = getTagIndex(projects);
const timelineItems = projects.map((project) => ({
  slug: project.id,
  title: project.data.title,
  summary: project.data.summary,
  tags: project.data.tags,
  date: formatProjectDate(project.data.date),
  cover: {
    src: project.data.cover.src,
    width: project.data.cover.width,
    height: project.data.cover.height,
    alt: project.data.coverAlt
  },
  liveUrl: project.data.liveUrl
}));
const galleryProjects = projects.map((project) => ({
  slug: project.id,
  title: project.data.title,
  summary: project.data.summary,
  tags: project.data.tags,
  date: formatProjectDate(project.data.date),
  cover: {
    src: project.data.cover.src,
    width: project.data.cover.width,
    height: project.data.cover.height,
    alt: project.data.coverAlt
  }
}));

const hasProjects = projects.length > 0;
---

<SiteLayout title={siteProfile.seo.title} description={siteProfile.seo.description}>
  <DynamicSidebar client:idle mode="home" projectCount={projects.length} tagCount={tags.length} />
  <HeroBanner projectCount={projects.length} tagCount={tags.length} />

  <section id="timeline" class="space-y-6 md:space-y-8">
    <SectionHeading
      eyebrowZh="时间线视图"
      eyebrowEn="Timeline View"
      titleZh="按时间追踪完整项目脉络"
      titleEn="Trace the work as a chronological system"
      descriptionZh="按日期倒序浏览项目。每条记录都保留封面、摘要与技术标签，适合快速扫读。"
      descriptionEn="Browse work in reverse chronological order with a concise cover, summary, and stack preview."
    />
    {hasProjects ? (
      <CompactTimeline client:visible items={timelineItems} basePath={import.meta.env.BASE_URL} />
    ) : (
      <div class="py-6 text-sm leading-7 text-fog-700 dark:text-fog-300 md:py-7 md:text-base">
        <p>项目内容正在整理中，近期会逐步补充真实案例、实现过程与上线结果。</p>
        <p class="mt-2 text-fog-500 dark:text-fog-500">
          Project case studies are being prepared and will be published here soon.
        </p>
      </div>
    )}
  </section>

  <section id="gallery" class="space-y-6 md:space-y-8">
    <SectionHeading
      eyebrowZh="画廊过滤视图"
      eyebrowEn="Gallery View"
      titleZh="用技术标签快速切片全部作品"
      titleEn="Slice the portfolio by stack and capability"
      descriptionZh="标签会从全部项目自动聚合。筛选时使用平滑重排动画，保持低噪音、高秩序的浏览感。"
      descriptionEn="Tags are aggregated from the whole collection and filtered with smooth layout animation."
    />
    {hasProjects ? (
      <GalleryFilter
        client:visible
        basePath={import.meta.env.BASE_URL}
        projects={galleryProjects}
        tags={tags}
        labels={siteProfile.ui.gallery}
      />
    ) : (
      <div class="py-6 text-sm leading-7 text-fog-700 dark:text-fog-300 md:py-7 md:text-base">
        <p>画廊区域暂时保留为空，用于后续展示真实项目截图、技术栈与线上预览。</p>
        <p class="mt-2 text-fog-500 dark:text-fog-500">
          This gallery will be filled with real projects, stack tags, and live previews.
        </p>
      </div>
    )}
  </section>
</SiteLayout>
