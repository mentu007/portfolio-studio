---
import LocaleText from './LocaleText.astro';
import { siteProfile } from '../data/site';
---


<footer class="mt-auto border-t border-fog-200 py-10 dark:border-fog-800">
  <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
    <div class="space-y-3">
      <LocaleText zh="保持联系" en="Stay in touch" class="text-[0.68rem] font-medium uppercase tracking-[0.34em] text-fog-500" />
      <p class="max-w-2xl text-sm leading-7 text-fog-700 dark:text-fog-300 md:text-base">
        {siteProfile.email}
      </p>
      <div class="flex flex-wrap gap-3 text-sm text-fog-700 dark:text-fog-300">
        {siteProfile.socials.map((item) => (
          <a
            class="text-fog-700 transition hover:text-fog-950 dark:text-fog-300 dark:hover:text-white"
            href={item.href}
            target={item.href.startsWith('http') ? '_blank' : undefined}
            rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <div class="text-right text-xs font-mono uppercase tracking-[0.32em] text-fog-500 dark:text-fog-500">
      <p>Astro / Tailwind / React Islands</p>
      <p class="mt-2">Static-first portfolio architecture</p>
    </div>
  </div>
</footer>
