---
import { Image } from 'astro:assets';
import type { ProjectEntry } from '../utils/projects';
import LocaleText from './LocaleText.astro';
import { siteProfile } from '../data/site';
import { formatProjectDate } from '../utils/projects';

interface Props {
  project: ProjectEntry;
  videoSrc: string | null;
}

const { project, videoSrc } = Astro.props;
const videoType = videoSrc?.endsWith('.webm') ? 'video/webm' : 'video/mp4';
const hasLinks = Boolean(project.data.repoUrl || project.data.liveUrl);
---

<section
  id="project-cover"
  class="relative scroll-mt-24 overflow-hidden rounded-[2.15rem] border border-fog-200/80 bg-[#f6f8fb] text-fog-950 shadow-[0_42px_120px_rgba(148,163,184,0.22)] transition-[background-color,border-color,box-shadow,color] duration-300 dark:border-slate-900/60 dark:bg-[#02050d] dark:text-white dark:shadow-[0_38px_120px_rgba(2,6,23,0.52)] lg:scroll-mt-10"
>
  <div class="absolute inset-0 overflow-hidden">
    {videoSrc ? (
      <video
        class="h-full w-full object-cover opacity-60 transition-opacity duration-300 dark:opacity-75"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={project.data.cover.src}
        aria-hidden="true"
      >
        <source src={videoSrc} type={videoType} />
      </video>
    ) : (
      <>
        <Image
          src={project.data.cover}
          alt={project.data.coverAlt}
          widths={[960, 1440, 1920]}
          sizes="100vw"
          class="absolute inset-0 h-full w-full scale-[1.02] object-cover opacity-50 transition-[opacity,transform] duration-300 dark:opacity-80"
        />
        <Image
          src={project.data.cover}
          alt=""
          widths={[960, 1440, 1920]}
          sizes="100vw"
          class="absolute inset-0 h-full w-full scale-[1.14] object-cover opacity-45 blur-3xl transition-opacity duration-300 dark:opacity-30"
        />
      </>
    )}

    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(248,250,252,0.97)_0%,rgba(248,250,252,0.91)_26%,rgba(248,250,252,0.62)_56%,rgba(255,255,255,0.18)_100%)] transition-colors duration-300 dark:bg-[linear-gradient(90deg,rgba(2,6,23,0.97)_0%,rgba(2,6,23,0.93)_30%,rgba(2,6,23,0.66)_58%,rgba(2,6,23,0.22)_100%)]" />
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(255,255,255,0.88),transparent_26%),radial-gradient(circle_at_70%_22%,rgba(255,255,255,0.72),transparent_22%),radial-gradient(circle_at_78%_84%,rgba(148,163,184,0.18),transparent_26%)] transition-colors duration-300 dark:bg-[radial-gradient(circle_at_18%_18%,rgba(56,189,248,0.18),transparent_28%),radial-gradient(circle_at_78%_24%,rgba(248,113,113,0.18),transparent_24%),radial-gradient(circle_at_74%_78%,rgba(255,255,255,0.08),transparent_28%)]" />
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(248,250,252,0.14)_0%,rgba(248,250,252,0.24)_35%,rgba(248,250,252,0.94)_100%)] transition-colors duration-300 dark:bg-[linear-gradient(180deg,rgba(2,6,23,0.1)_0%,rgba(2,6,23,0.18)_38%,rgba(2,6,23,0.82)_100%)] lg:hidden" />
    <div class="absolute inset-0 ring-1 ring-inset ring-fog-200/70 transition-colors duration-300 dark:ring-white/8" />
  </div>

  <div class="relative grid min-h-[520px] gap-8 px-6 py-8 md:min-h-[580px] md:px-8 md:py-10 lg:grid-cols-[minmax(0,0.46fr),minmax(0,0.54fr)] lg:px-10 lg:py-12">
    <div class="flex max-w-xl flex-col justify-between gap-8 lg:gap-10">
      <div class="space-y-6">
        <div class="flex flex-wrap gap-3 text-[0.68rem] font-mono uppercase tracking-[0.28em] text-fog-600 transition-colors duration-300 dark:text-white/62">
          <span class="rounded-full border border-fog-200/90 bg-white/55 px-3 py-1.5 shadow-[0_8px_30px_rgba(255,255,255,0.36)] backdrop-blur-sm transition-[background-color,border-color,color,box-shadow] duration-300 dark:border-white/12 dark:bg-white/10 dark:shadow-none">
            {formatProjectDate(project.data.date, 'full')}
          </span>
          <span class="rounded-full border border-fog-200/90 bg-white/55 px-3 py-1.5 shadow-[0_8px_30px_rgba(255,255,255,0.36)] backdrop-blur-sm transition-[background-color,border-color,color,box-shadow] duration-300 dark:border-white/12 dark:bg-white/10 dark:shadow-none">
            /{project.id}
          </span>
        </div>

        <div class="space-y-4">
          <h1 class="max-w-3xl text-4xl font-semibold tracking-[-0.055em] text-fog-950 transition-colors duration-300 dark:text-white md:text-5xl lg:text-[4rem] lg:leading-[0.96]">
            {project.data.title}
          </h1>
          <p class="max-w-xl text-sm leading-7 text-fog-700 transition-colors duration-300 dark:text-slate-200/85 md:text-base md:leading-8">
            {project.data.summary}
          </p>
        </div>

        <div class="flex flex-wrap gap-2.5">
          {project.data.tags.map((tag) => (
            <span class="rounded-full border border-fog-200/90 bg-white/58 px-3 py-1 text-xs font-medium text-fog-700 shadow-[0_10px_30px_rgba(255,255,255,0.3)] backdrop-blur-sm transition-[background-color,border-color,color,box-shadow] duration-300 dark:border-white/12 dark:bg-white/10 dark:text-white/85 dark:shadow-none">
              {tag}
            </span>
          ))}
        </div>
      </div>

      {hasLinks && (
        <div class="flex flex-wrap gap-x-6 gap-y-3 border-t border-fog-200/80 pt-5 text-sm font-medium transition-colors duration-300 dark:border-white/10">
          {project.data.repoUrl && (
            <a
              href={project.data.repoUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 border-b border-fog-300/90 pb-1 text-fog-800 transition-[border-color,color] duration-300 hover:border-fog-700 hover:text-fog-950 dark:border-white/18 dark:text-white/82 dark:hover:border-white/70 dark:hover:text-white"
            >
              <LocaleText zh={siteProfile.ui.sections.repository.zh} en={siteProfile.ui.sections.repository.en} />
              <span aria-hidden="true">-&gt;</span>
            </a>
          )}
          {project.data.liveUrl && (
            <a
              href={project.data.liveUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 border-b border-fog-300/90 pb-1 text-fog-800 transition-[border-color,color] duration-300 hover:border-fog-700 hover:text-fog-950 dark:border-white/18 dark:text-white/82 dark:hover:border-white/70 dark:hover:text-white"
            >
              <LocaleText zh={siteProfile.ui.sections.liveDemo.zh} en={siteProfile.ui.sections.liveDemo.en} />
              <span aria-hidden="true">-&gt;</span>
            </a>
          )}
        </div>
      )}
    </div>

    <div class="hidden lg:block" aria-hidden="true" />
  </div>
</section>
