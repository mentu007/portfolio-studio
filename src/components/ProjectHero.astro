---
import { Image } from 'astro:assets';
import type { ProjectEntry } from '../utils/projects';
import LocaleText from './LocaleText.astro';
import { siteProfile } from '../data/site';
import { formatProjectDate } from '../utils/projects';

interface Props {
  project: ProjectEntry;
  videoSrc: string | null;
}

const { project, videoSrc } = Astro.props;
const videoType = videoSrc?.endsWith('.webm') ? 'video/webm' : 'video/mp4';
---

<section class="surface-panel overflow-hidden px-5 py-5 md:px-8 md:py-8">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,0.86fr),minmax(360px,1fr)] lg:items-start">
    <div class="space-y-5">
      <p class="section-eyebrow">{formatProjectDate(project.data.date, 'full')}</p>
      <h1 class="max-w-3xl text-3xl font-semibold tracking-[-0.05em] text-fog-900 md:text-5xl">
        {project.data.title}
      </h1>
      <p class="max-w-2xl text-sm leading-7 text-fog-700 md:text-base">{project.data.summary}</p>

      <div class="flex flex-wrap gap-2">
        {project.data.tags.map((tag) => (
          <span class="rounded-full border border-fog-200 bg-white/85 px-3 py-1 text-xs font-medium text-fog-700">
            {tag}
          </span>
        ))}
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        {project.data.repoUrl && (
          <a
            href={project.data.repoUrl}
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-fog-900 bg-fog-900 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-fog-800"
          >
            <LocaleText zh={siteProfile.ui.sections.repository.zh} en={siteProfile.ui.sections.repository.en} />
          </a>
        )}
        {project.data.liveUrl && (
          <a
            href={project.data.liveUrl}
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-fog-300 bg-white/80 px-4 py-2.5 text-sm font-medium text-fog-700 transition hover:border-fog-500 hover:text-fog-900"
          >
            <LocaleText zh={siteProfile.ui.sections.liveDemo.zh} en={siteProfile.ui.sections.liveDemo.en} />
          </a>
        )}
      </div>
    </div>

    <div class="overflow-hidden rounded-[1.75rem] border border-fog-200 bg-white">
      {videoSrc ? (
        <video
          class="aspect-video h-full w-full bg-fog-950 object-cover"
          controls
          preload="metadata"
          poster={project.data.cover.src}
        >
          <source src={videoSrc} type={videoType} />
        </video>
      ) : (
        <div class="grid gap-5 p-5 md:p-6">
          <Image
            src={project.data.cover}
            alt={project.data.coverAlt}
            widths={[720, 1280]}
            sizes="(max-width: 1024px) 100vw, 48vw"
            class="aspect-video h-full w-full rounded-[1.25rem] object-cover"
          />
          <LocaleText
            zh={siteProfile.ui.sections.videoFallback.zh}
            en={siteProfile.ui.sections.videoFallback.en}
            tag="p"
            class="text-sm leading-7 text-fog-600"
          />
        </div>
      )}
    </div>
  </div>
</section>
