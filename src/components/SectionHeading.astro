---
import LocaleText from './LocaleText.astro';

interface Props {
  eyebrowZh: string;
  eyebrowEn: string;
  titleZh: string;
  titleEn: string;
  descriptionZh: string;
  descriptionEn: string;
}

const {
  eyebrowZh,
  eyebrowEn,
  titleZh,
  titleEn,
  descriptionZh,
  descriptionEn
} = Astro.props;
---

<div class="section-shell">
  <LocaleText zh={eyebrowZh} en={eyebrowEn} class="section-eyebrow" />
  <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1.1fr),minmax(0,0.9fr)] lg:items-end">
    <LocaleText
      zh={titleZh}
      en={titleEn}
      tag="h2"
      class="max-w-4xl text-2xl font-semibold tracking-[-0.04em] text-fog-900 dark:text-slate-50 md:text-4xl"
    />
    <LocaleText
      zh={descriptionZh}
      en={descriptionEn}
      tag="p"
      class="max-w-2xl text-sm leading-7 text-fog-700 dark:text-slate-300 md:text-base"
    />
  </div>
</div>
