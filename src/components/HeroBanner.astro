---
import LocaleText from './LocaleText.astro';
import LocaleToggle from './LocaleToggle.astro';
import { siteProfile } from '../data/site';

interface Props {
  projectCount: number;
  tagCount: number;
}

const { projectCount, tagCount } = Astro.props;
---

<section class="surface-panel hero-card overflow-hidden px-5 py-5 md:px-8 md:py-8">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr),minmax(320px,0.9fr)] lg:items-end">
    <div class="space-y-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="section-eyebrow">{siteProfile.location}</p>
          <h1 class="mt-3 max-w-4xl text-4xl font-semibold tracking-[-0.06em] text-fog-900 md:text-6xl lg:text-[5.4rem]">
            {siteProfile.name}
          </h1>
        </div>
        <LocaleToggle />
      </div>

      <LocaleText
        zh={siteProfile.tagline.zh}
        en={siteProfile.tagline.en}
        tag="p"
        class="max-w-3xl text-lg leading-8 text-fog-800 md:text-2xl md:leading-10"
      />
      <LocaleText
        zh={siteProfile.intro.zh}
        en={siteProfile.intro.en}
        tag="p"
        class="max-w-2xl text-sm leading-7 text-fog-700 md:text-base"
      />

      <div class="flex flex-wrap gap-3">
        <a
          href="#timeline"
          class="rounded-full border border-fog-900 bg-fog-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-fog-800"
        >
          <LocaleText zh={siteProfile.ui.homeCtas.timeline.zh} en={siteProfile.ui.homeCtas.timeline.en} />
        </a>
        <a
          href="#gallery"
          class="rounded-full border border-fog-300 bg-white/75 px-5 py-3 text-sm font-medium text-fog-800 transition hover:border-fog-500 hover:text-fog-900"
        >
          <LocaleText zh={siteProfile.ui.homeCtas.gallery.zh} en={siteProfile.ui.homeCtas.gallery.en} />
        </a>
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
      <div class="rounded-[1.4rem] border border-fog-200 bg-white/80 p-5">
        <LocaleText zh={siteProfile.ui.heroStats.projects.zh} en={siteProfile.ui.heroStats.projects.en} class="section-eyebrow" />
        <p class="mt-4 font-mono text-3xl text-fog-900">{projectCount.toString().padStart(2, '0')}</p>
      </div>
      <div class="rounded-[1.4rem] border border-fog-200 bg-white/80 p-5">
        <LocaleText zh={siteProfile.ui.heroStats.tags.zh} en={siteProfile.ui.heroStats.tags.en} class="section-eyebrow" />
        <p class="mt-4 font-mono text-3xl text-fog-900">{tagCount.toString().padStart(2, '0')}</p>
      </div>
      <div class="rounded-[1.4rem] border border-fog-200 bg-white/80 p-5">
        <LocaleText zh={siteProfile.ui.heroStats.hosting.zh} en={siteProfile.ui.heroStats.hosting.en} class="section-eyebrow" />
        <p class="mt-4 text-sm leading-7 text-fog-700">GitHub Pages / static export / MDX content</p>
      </div>
    </div>
  </div>
</section>
