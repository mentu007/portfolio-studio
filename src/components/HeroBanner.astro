---
import LocaleText from './LocaleText.astro';
import { siteProfile } from '../data/site';

interface Props {
  projectCount?: number;
  tagCount?: number;
}

const { projectCount = 0, tagCount = 0 } = Astro.props;
---

<section class="surface-panel hero-card overflow-hidden px-5 py-6 md:px-8 md:py-8">
  <div class="space-y-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="section-eyebrow">{siteProfile.location}</p>
        <h1 class="mt-3 max-w-4xl text-[2.65rem] font-semibold tracking-[-0.05em] text-fog-900 dark:text-slate-50 md:text-5xl lg:text-[4.25rem]">
          {siteProfile.name}
        </h1>
      </div>

      <div class="rounded-full border border-fog-200/80 bg-white/72 px-4 py-2 text-[0.68rem] font-mono uppercase tracking-[0.3em] text-fog-500 shadow-sm backdrop-blur dark:border-slate-700/80 dark:bg-slate-900/72 dark:text-slate-400">
        {projectCount.toString().padStart(2, '0')} / {tagCount.toString().padStart(2, '0')}
      </div>
    </div>

    <LocaleText
      zh={siteProfile.tagline.zh}
      en={siteProfile.tagline.en}
      tag="p"
      class="max-w-3xl text-lg leading-8 text-fog-800 dark:text-slate-200 md:text-2xl md:leading-10"
    />

    <div class="flex flex-wrap gap-3">
      <a
        href="#timeline"
        class="rounded-full border border-fog-900 bg-fog-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-fog-800 dark:border-slate-100 dark:bg-slate-100 dark:text-slate-950 dark:hover:bg-slate-200"
      >
        <LocaleText zh={siteProfile.ui.homeCtas.timeline.zh} en={siteProfile.ui.homeCtas.timeline.en} />
      </a>
      <a
        href="#gallery"
        class="rounded-full border border-fog-300 bg-white/75 px-5 py-3 text-sm font-medium text-fog-800 transition hover:border-fog-500 hover:text-fog-900 dark:border-slate-700/80 dark:bg-slate-900/72 dark:text-slate-100 dark:hover:border-slate-500 dark:hover:text-white"
      >
        <LocaleText zh={siteProfile.ui.homeCtas.gallery.zh} en={siteProfile.ui.homeCtas.gallery.en} />
      </a>
    </div>

    <div class="flex flex-wrap gap-3 border-t border-fog-200/80 pt-4 text-[0.7rem] font-mono uppercase tracking-[0.26em] text-fog-500 dark:border-slate-700/80 dark:text-slate-400">
      <span class="rounded-full border border-fog-200/80 bg-white/72 px-3 py-2 dark:border-slate-700/80 dark:bg-slate-900/72">
        Astro
      </span>
      <span class="rounded-full border border-fog-200/80 bg-white/72 px-3 py-2 dark:border-slate-700/80 dark:bg-slate-900/72">
        React Islands
      </span>
      <span class="rounded-full border border-fog-200/80 bg-white/72 px-3 py-2 dark:border-slate-700/80 dark:bg-slate-900/72">
        MDX Content
      </span>
      <span class="rounded-full border border-fog-200/80 bg-white/72 px-3 py-2 dark:border-slate-700/80 dark:bg-slate-900/72">
        Glass Dock
      </span>
    </div>
  </div>
</section>
