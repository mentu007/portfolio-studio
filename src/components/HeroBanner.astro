---
import LocaleText from './LocaleText.astro';
import { siteProfile } from '../data/site';

interface Props {
  projectCount?: number;
  tagCount?: number;
}

const { projectCount = 0, tagCount = 0 } = Astro.props;
---

<section class="fade-in-up pt-2">
  <div class="space-y-8">
    <div class="space-y-4">
      <LocaleText
        zh={siteProfile.location.zh}
        en={siteProfile.location.en}
        tag="p"
        class="text-[0.68rem] font-medium uppercase tracking-[0.34em] text-fog-500"
      />
      <LocaleText
        zh={siteProfile.name.zh}
        en={siteProfile.name.en}
        tag="h1"
        class="font-serif max-w-4xl text-[2.65rem] font-bold tracking-[0.04em] text-fog-950 dark:text-fog-50 md:text-5xl lg:text-[4.25rem]"
      />
    </div>

    <LocaleText
      zh={siteProfile.tagline.zh}
      en={siteProfile.tagline.en}
      tag="p"
      class="max-w-3xl text-base leading-8 text-fog-700 dark:text-fog-300 md:text-lg md:leading-9"
    />

    <div class="flex flex-wrap gap-3">
      <a
        href="#timeline"
        class="rounded-full bg-fog-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-fog-800 dark:bg-white dark:text-fog-950 dark:hover:bg-fog-100"
      >
        <LocaleText zh={siteProfile.ui.homeCtas.timeline.zh} en={siteProfile.ui.homeCtas.timeline.en} />
      </a>
      <a
        href="#gallery"
        class="rounded-full border border-fog-200 px-5 py-3 text-sm font-medium text-fog-800 transition hover:border-fog-400 hover:text-fog-950 dark:border-fog-700 dark:text-fog-200 dark:hover:border-fog-500 dark:hover:text-white"
      >
        <LocaleText zh={siteProfile.ui.homeCtas.gallery.zh} en={siteProfile.ui.homeCtas.gallery.en} />
      </a>
    </div>

    <div class="flex flex-wrap gap-2 pt-2">
      <span class="rounded-full bg-fog-100 px-3 py-1.5 text-[0.7rem] font-medium uppercase tracking-[0.2em] text-fog-600 dark:bg-fog-800 dark:text-fog-400">
        Astro
      </span>
      <span class="rounded-full bg-fog-100 px-3 py-1.5 text-[0.7rem] font-medium uppercase tracking-[0.2em] text-fog-600 dark:bg-fog-800 dark:text-fog-400">
        React Islands
      </span>
      <span class="rounded-full bg-fog-100 px-3 py-1.5 text-[0.7rem] font-medium uppercase tracking-[0.2em] text-fog-600 dark:bg-fog-800 dark:text-fog-400">
        MDX Content
      </span>
      <span class="rounded-full bg-fog-100 px-3 py-1.5 text-[0.7rem] font-medium uppercase tracking-[0.2em] text-fog-600 dark:bg-fog-800 dark:text-fog-400">
        Glass Dock
      </span>
    </div>
  </div>
</section>
